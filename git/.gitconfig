[user]
    name = Ayoub Ghodhbane
    email = ghodhbaneayoub@gmail.com

[init]
    defaultBranch = main

[core]
    editor = code --wait
    autocrlf = input
    whitespace = fix
    pager = delta

[pull]
    rebase = true

[push]
    autoSetupRemote = true
    default = current

[fetch]
    prune = true

[diff]
    colorMoved = default

[merge]
    conflictstyle = diff3

[alias]
    st = status -sb
    co = checkout
    br = branch
    ci = commit
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    last = log -1 HEAD --stat
    unstage = reset HEAD --
    amend = commit --amend --no-edit
    undo = reset --soft HEAD~1
    wip = !git add -A && git commit -m "wip: work in progress"
    nuke = !git reset --hard HEAD && git clean -fd
    branches = branch -a --sort=-committerdate
    stashes = stash list
    remotes = remote -v
    contributors = shortlog --summary --numbered
    diff-staged = diff --cached
    cleanup = !git branch --merged main | grep -v 'main' | xargs git branch -d

[color]
    ui = auto

[credential]
    helper = manager

[rerere]
    enabled = true
